# =============================================================================
# Musawo AI — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# ── Application ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=info               # debug | info | warning | error
PORT=8000
WORKERS=2

# ── LLM Backend ─────────────────────────────────────────────────────────────
LLM_BACKEND=claude           # "claude" (API) or "local" (Qwen3-8B offline)

# Claude API (primary)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6-20250514
CLAUDE_THINKING_BUDGET=10000
CLAUDE_PROMPT_CACHING=true
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.3

# Local model (offline fallback)
LLM_MODEL=Qwen/Qwen3-8B
LLM_CONTEXT_WINDOW=8192
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2
LLM_DEVICE=auto              # auto | cpu | cuda

# ── Vector Store (Qdrant) ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=musawo_health_kb
DENSE_MODEL=BAAI/bge-m3
DENSE_DIM=1024
RERANKER_MODEL=mixedbread-ai/mxbai-rerank-base-v2
RERANK_ENABLED=true
BM25_STATE_PATH=knowledge-base/bm25_state.json

# ── Guardrails ──────────────────────────────────────────────────────────────
MAX_INPUT_LENGTH=2000
ABSTENTION_THRESHOLD=0.15
ESCALATION_THRESHOLD=0.25
GROUNDING_THRESHOLD=0.3

# ── CORS & Frontend ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://api:8000

# ── Ports ───────────────────────────────────────────────────────────────────
API_PORT=8000
FRONTEND_PORT=3000
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# ── Timeouts ────────────────────────────────────────────────────────────────
LLM_INFERENCE_TIMEOUT=45
QDRANT_TIMEOUT=30
REQUEST_TIMEOUT=120

# ── Session ─────────────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=86400    # 24 hours

# ── Privacy (Uganda Data Protection Act compliance) ─────────────────────────
STORE_RAW_PROMPTS=false
CONVERSATION_TTL_DAYS=7
FEEDBACK_TTL_DAYS=90

# ── Twilio SMS ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ── Monitoring (optional) ──────────────────────────────────────────────────
GRAFANA_PASSWORD=musawo

# ── HuggingFace (for model downloads) ──────────────────────────────────────
HF_TOKEN=hf_your_token_here
